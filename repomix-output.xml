                </form>

                <p className="text-xs text-center mt-4 text-gray-500">
                    ¿Ya tienes cuenta?{" "}
                    <Link to="/login" className="text-black font-semibold">
                        Inicia sesión
                    </Link>
                </p>
            </div>
        </div>
    );
}
